{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "rebaseWhen": "behind-base-branch",
  "separateMajorMinor": false,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Match renovate tags for container images",
      "managerFilePatterns": [
        "/(^|/)ansible/inventory/.+\\.ya?ml$/",
        "/(^|/)ansible/roles/.+/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "# renovate:\\s+datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\n\\s*[A-Za-z0-9_]+:\\s+\"?(?<currentValue>[^\"\\s#]+)\"?"
      ]
    },
    {
      "customType": "regex",
      "description": "Match renovate tags for Debian package pins",
      "managerFilePatterns": [
        "/(^|/)ansible/inventory/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate:\\s+suite=(?<suite>\\S+) depName=(?<depName>\\S+)\\n\\s*[A-Za-z0-9_]+:\\s+\"?(?<currentValue>[^\"\\s#]+)\"?"
      ],
      "datasourceTemplate": "deb",
      "versioningTemplate": "deb",
      "registryUrlTemplate": "https://deb.debian.org/debian?suite={{suite}}&components=main,contrib,non-free,non-free-firmware&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "description": "Match renovate tags for Debian package pins with explicit arch",
      "managerFilePatterns": [
        "/(^|/)ansible/inventory/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate:\\s+suite=(?<suite>\\S+) arch=(?<arch>\\S+) depName=(?<depName>\\S+)\\n\\s*[A-Za-z0-9_]+:\\s+\"?(?<currentValue>[^\"\\s#]+)\"?"
      ],
      "datasourceTemplate": "deb",
      "versioningTemplate": "deb",
      "registryUrlTemplate": "https://deb.debian.org/debian?suite={{suite}}&components=main,contrib,non-free,non-free-firmware&binaryArch={{arch}}"
    }
  ],
  "packageRules": [
    {
      "description": "Immich - group server and ML container updates together",
      "groupName": "immich",
      "matchDepNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ]
    },
    {
      "description": "Immich postgres - pin to pg14",
      "matchDatasources": ["docker"],
      "matchDepNames": ["ghcr.io/immich-app/postgres"],
      "allowedVersions": "/^14-/"
    },
    {
      "description": "Security - automerge immediately",
      "prPriority": 100,
      "matchCategories": ["security"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "0 days",
      "labels": ["renovate", "security"]
    },
    {
      "description": "Patch - automerge after 1 day",
      "prPriority": 50,
      "matchUpdateTypes": ["patch"],
      // "automerge": true,
      // "automergeType": "pr",
      "automerge": false,
      "minimumReleaseAge": "1 day",
      "labels": ["renovate", "patch"]
    },
    {
      "description": "Minor - automerge after 7 days",
      "prPriority": 40,
      "matchUpdateTypes": ["minor"],
      // "automerge": true,
      // "automergeType": "pr",
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "labels": ["renovate", "minor"]
    },
    {
      "description": "Major - manual review",
      "prPriority": 10,
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "needs-review"]
    },
    {
      "description": "Podman Debian security - automerge after short soak",
      "matchDatasources": ["deb"],
      "matchDepNames": ["podman"],
      "matchCategories": ["security"],
      "prPriority": 110,
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "6 hours",
      "labels": ["renovate", "security", "podman-runtime"]
    },
    {
      "description": "Podman Debian patch - automerge after 1 day",
      "matchDatasources": ["deb"],
      "matchDepNames": ["podman"],
      "matchUpdateTypes": ["patch"],
      "prPriority": 60,
      // "automerge": true,
      // "automergeType": "pr",
      "automerge": false,
      "minimumReleaseAge": "1 day",
      "labels": ["renovate", "patch", "podman-runtime"]
    },
    {
      "description": "Podman Debian minor - automerge after 3 days",
      "matchDatasources": ["deb"],
      "matchDepNames": ["podman"],
      "matchUpdateTypes": ["minor"],
      "prPriority": 55,
      // "automerge": true,
      // "automergeType": "pr",
      "automerge": false,
      "minimumReleaseAge": "3 days",
      "labels": ["renovate", "minor", "podman-runtime"]
    },
    {
      "description": "Podman Debian major - manual review",
      "matchDatasources": ["deb"],
      "matchDepNames": ["podman"],
      "matchUpdateTypes": ["major"],
      "prPriority": 20,
      "automerge": false,
      "labels": ["renovate", "needs-review", "podman-runtime"]
    },
    {
      "description": "HomeOps Apps, automerge after global 3-day soak",
      "groupName": "arr-apps",
      "matchDatasources": ["docker"],
      "matchDepPatterns": ["^ghcr\\.io/home-operations/"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["renovate", "arr-apps"]
    },
    {
      "description": "Arr tooling, automerge after global 3-day soak",
      "groupName": "arr-tooling",
      "matchDatasources": ["docker"],
      "matchDepNames": [
        "ghcr.io/recyclarr/recyclarr",
        "ghcr.io/dictionarry-hub/profilarr",
        "ghcr.io/dictionarry-hub/profilarr-parser",
        "luigi311/jellyplex-watched"
      ],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["renovate", "arr-tooling"]
    },
    {
      "description": "Jellyfin, automerge after global 3-day soak",
      "groupName": "jellyfin",
      "matchDatasources": ["docker"],
      "matchDepNames": [
        "ghcr.io/jellyfin/jellyfin"
      ],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["renovate", "jellyfin"]
    }
  ]
}
