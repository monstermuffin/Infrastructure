// fastfetch config — Ansible managed
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "padding": {
            "right": 2
        }
    },
    "display": {
        "separator": ": ",
        "color": {
            "keys": "38;2;216;180;254",
            "title": "38;2;216;180;254",
            "output": "white"
        }
    },
    "modules": [
        "title",
        {
            "type": "separator",
            "string": "---"
        },
        "os",
        "host",
        "kernel",
        "uptime",
        "packages",
        "shell",
        {
            "type": "display",
            "compact": true
        },
        "terminal",
        "cpu",
        {
            "type": "gpu",
            "driverSpecific": false
        },
        "memory",
        "swap",
        {
            "type": "disk",
            "key": "Disk ({})"
        },
        "localip",
        "break",
        "colors"
    ]
}
