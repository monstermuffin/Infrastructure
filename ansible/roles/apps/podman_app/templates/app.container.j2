# {{ ansible_managed }}

[Unit]
Description={{ _app.description | default(_app_name | title) }}
After=network-online.target{% for dep in _app.after | default([]) %} {{ dep }}{% endfor %}

Wants=network-online.target
{% for dep in _app.requires | default([]) %}
Requires={{ dep }}
{% endfor %}

[Container]
Image={{ _app.image }}:{{ _app.tag | default('latest') }}
ContainerName={{ _app.container_name | default(_app_name) }}
{% if _app.user is defined %}
User={{ _app.user }}
{% endif %}

{% if _app.network_mode is defined %}
Network={{ _app.network_mode }}
{% elif _app.networks is defined %}
{%   for net in _app.networks %}
Network={{ net }}
{%   endfor %}
{% elif _app.network is defined %}
Network={{ _app.network }}
{% endif %}
{% if (_app.network_mode | default('')) != 'host' %}
{%   if _app.ports is defined %}
{%     for port in _app.ports %}
PublishPort={{ port }}
{%     endfor %}
{%   elif _app.port is defined %}
PublishPort={{ _app.port }}:{{ _app.container_port | default(_app.port) }}
{%   endif %}
{% endif %}

{% for vol in _app.volumes | default([]) %}
Volume={{ vol }}
{% endfor %}

{% for path in _app.tmpfs | default([]) %}
Tmpfs={{ path }}
{% endfor %}

{% for key, value in (_app.env | default({})).items() %}
Environment="{{ key }}={{ ((value | string) | replace('\\', '\\\\') | replace('"', '\\"')) | replace('%', '%%') }}"
{% endfor %}

{% if _app.exec is defined %}
Exec={{ _app.exec }}
{% endif %}

{% for device in _app.devices | default([]) %}
AddDevice={{ device }}
{% endfor %}

{% for cap in _app.cap_add | default([]) %}
AddCapability={{ cap }}
{% endfor %}

{% if _app.shm_size is defined %}
ShmSize={{ _app.shm_size }}
{% endif %}

{% if _app.userns is defined %}
UserNS={{ _app.userns }}
{% endif %}

{% for arg in _app.podman_args | default([]) %}
PodmanArgs={{ arg }}
{% endfor %}

{% if _app.privileged | default(false) %}
SecurityLabelDisable=true
PodmanArgs=--privileged
{% elif _app.security_label_disable | default(false) %}
SecurityLabelDisable=true
{% endif %}

{% for label, value in (_app.labels | default({})).items() %}
Label={{ label }}={{ value }}
{% endfor %}

[Service]
# Force-remove any stale container entry from Podman's DB before starting.
# Attmept to fix stale Netavark nftables DNAT rules.
ExecStartPre=-/usr/bin/podman rm --ignore --force {{ _app.container_name | default(_app_name) }}
Restart={{ _app.restart | default('always') }}
{% if _app.restart_sec is defined %}
RestartSec={{ _app.restart_sec }}
{% endif %}

[Install]
WantedBy=multi-user.target
